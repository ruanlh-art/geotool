# GEMINI_API_KEY: Required for Gemini AI API calls.
# In AI Studio, this is automatically injected.
# For Netlify/Vercel, add this key in your project's Environment Variables settings.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# For Netlify/Vercel, this is usually your site's domain (e.g., https://your-site.netlify.app).
APP_URL="https://your-site.netlify.app"
